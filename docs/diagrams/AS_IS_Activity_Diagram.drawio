        <mxCell id="a2" value="&lt;b&gt;Отправляет обращение&lt;/b&gt;&lt;br/&gt;&lt;font color=&apos;#475569&apos; style=&apos;font-size:10px;&apos;&gt;звонок / email / мессенджер&lt;/font&gt;"
