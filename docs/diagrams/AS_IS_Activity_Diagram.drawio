        <!-- ===== КЛИЕНТ ===== -->
        <mxCell id="a1" value="&lt;b&gt;Клиент формулирует заявку&lt;/b&gt;&lt;br/&gt;&lt;font color=&apos;#475569&apos; style=&apos;font-size:10px;&apos;&gt;устно / по email&lt;/font&gt;"
